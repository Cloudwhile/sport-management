# Runtime config for dist-exe/sport-management.exe

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sport_management
DB_USER=postgres
DB_PASSWORD=change-this-password

JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://127.0.0.1:3000

LOG_TIME_OFFSET_MINUTES=480

AUTO_MIGRATE=true
AUTO_SEED=true
